from openai import OpenAI

# IMPORTANT: Replace 'api_key' with your actual OpenAI API key or use an environment variable.
client = OpenAI(api_key="api_key")

# For chat-based models, use client.chat.completions.create and pass 'messages'.
# The model name should also be a chat model (e.g., 'gpt-3.5-turbo', 'gpt-4').
response = client.chat.completions.create(
    model="gpt-3.5-turbo",
    messages=[
        {"role": "user", "content": "hello world"}
    ]
)

# Access the content from the response correctly for chat completions.
res = response.choices[0].message.content
print(res)


