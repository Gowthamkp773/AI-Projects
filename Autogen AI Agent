import requests

def get_wether(query:str):
  uri="https://openweathermap.org/"

  response=requests.get(url=uri)
  weather=response.json()

  if "main" in weather:
    return {
        "weather":[weather.get("weather")],
        "temp":weather.get("temp"),
    }

  else:
    print("not weather report")


