import requests
from mcp.server.fastmcp import FastMCP

@mcp.tool()
def weathertool(query:str):
  global api_key 
  if api_key == "YOUR_API_KEY":
      return "Error: Please replace 'YOUR_API_KEY' in cell 1YC4Zp5F0K2R with your actual OpenWeatherMap API key."
  url = f"http://api.openweathermap.org/data/2.5/weather?q={query}&appid={api_key}&units=metric"

  response = requests.get(url)

  if response.status_code == 200:
    data = response.json()
    city = data['name']
    country = data['sys']['country']
    temp = data['main']['temp']
    description = data['weather'][0]['description']
    return f"Weather in {city}, {country}: {description}, {temp}°C"
  else:
    return f"Error fetching weather data: {response.status_code} - {response.text}"

user_input="london"
result=weathertool(user_input)
print(result)

def weather(query):
  return weathertool(query)

if __name__ == "__main__":
  mcp.run()

